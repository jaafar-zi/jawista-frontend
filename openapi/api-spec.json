  "components": {
    "schemas": {
      "AddressDTO": {
        "required": [
          "addressLine1",
          "city",
          "country",
          "fullName",
          "phoneNumber",
          "postalCode",
          "state"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "fullName": {
            "type": "string"
          },
          "phoneNumber": {
            "pattern": "^[+]?[0-9]{10,15}$",
            "type": "string"
          },
          "addressLine1": {
            "type": "string"
          },
          "addressLine2": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "postalCode": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "isDefault": {
            "type": "boolean"
          },
          "customerEmail": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "formattedAddress": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ShippingDTO": {
        "required": [
          "carrier",
          "orderId",
          "shippingAddress",
          "shippingMethod"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "trackingNumber": {
            "type": "string"
          },
          "orderId": {
            "type": "integer",
            "format": "int64"
          },
          "orderNumber": {
            "type": "string"
          },
          "shippingAddress": {
            "$ref": "#/components/schemas/AddressDTO"
          },
          "shippingMethod": {
            "type": "string"
          },
          "currentStatus": {
            "type": "string"
          },
          "carrier": {
            "type": "string"
          },
          "shippingCost": {
            "type": "number"
          },
          "weight": {
            "type": "number"
          },
          "estimatedDeliveryDate": {
            "type": "string",
            "format": "date-time"
          },
          "actualDeliveryDate": {
            "type": "string",
            "format": "date-time"
          },
          "shippedDate": {
            "type": "string",
            "format": "date-time"
          },
          "specialInstructions": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "statusHistory": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ShippingStatusDTO"
            }
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ShippingStatusDTO": {
        "required": [
          "location",
          "shippingId",
          "status",
          "timestamp"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "shippingId": {
            "type": "integer",
            "format": "int64"
          },
          "status": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "description": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "updatedBy": {
